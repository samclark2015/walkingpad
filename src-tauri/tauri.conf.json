{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WalkingPad",
  "version": "0.1.0",
  "identifier": "com.sclark.walkingpad-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WalkingPad",
        "width": 420,
        "height": 780,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray-icon.png"],
    "macOS": {
      "entitlements": "entitlements.mac.plist",
      "infoPlist": "Info.plist"
    }
  }
}
