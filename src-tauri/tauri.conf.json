{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WalkingPad",
  "version": "0.1.0",
  "identifier": "me.samclark.walkingpadp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WalkingPad",
        "width": 480,
        "height": 600,
        "resizable": true,
        "minWidth": 420,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray-icon.png"],
    "macOS": {
      "entitlements": "entitlements.mac.plist",
      "infoPlist": "Info.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI2M0Q4RkRGODBGOTBDQkYKUldTL0RQbUEzNDg5dHJQV1k5RXp0NVV4SS9hNU52YVdOUDN4d2NGZVdtTFJtcmVsNW53NCtWQkEK",
      "endpoints": [
        "https://github.com/samclark2015/walkingpad/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
